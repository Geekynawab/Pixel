<div class="section">
  <div class="container" style="max-width:640px;text-align:center;">

    <h1 style="margin-bottom:0.5rem;">{{ 'gift_cards.issued.title' | t | default: 'Your gift card' }}</h1>

    {%- if gift_card.expired or gift_card.enabled == false -%}
      <p style="color:var(--color-accent);font-size:0.88rem;margin-bottom:1.5rem;">{{ 'gift_cards.issued.expired' | t | default: 'This gift card has expired.' }}</p>
    {%- else -%}
      <p style="color:var(--color-text-secondary);font-size:0.88rem;margin-bottom:1.5rem;">
        {{ 'gift_cards.issued.subtext' | t: expiry: gift_card.expires_on | date: '%B %d, %Y' | default: 'Use this code at checkout.' }}
      </p>
    {%- endif -%}

    <div style="background:var(--color-bg-card);border:1px solid var(--color-border);padding:2rem;margin-bottom:1.5rem;">
      <div style="font-size:1.5rem;letter-spacing:0.15em;font-weight:700;color:var(--color-accent);margin-bottom:1rem;">
        {{ gift_card.code | format_code }}
      </div>
      <p style="font-size:0.82rem;color:var(--color-text-secondary);">
        {{ 'gift_cards.issued.remaining_html' | t: balance: gift_card.balance | money | default: 'Balance remaining' }}
      </p>
    </div>

    <div style="display:flex;gap:1rem;justify-content:center;flex-wrap:wrap;margin-bottom:2rem;">
      <a href="{{ shop.url }}" class="btn btn--primary">{{ 'general.continue_shopping' | t | default: 'Shop now' }}</a>
      <button
        class="btn btn--outline"
        onclick="navigator.clipboard && navigator.clipboard.writeText('{{ gift_card.code }}').then(function(){this.textContent='Copied!';}.bind(this))"
        type="button">
        Copy code
      </button>
    </div>

    {%- if gift_card.pass_url -%}
      <a href="{{ gift_card.pass_url }}" style="display:inline-block;">
        <img src="{{ 'gift-card/add-to-apple-wallet.svg' | shopify_asset_url }}" width="120" height="40" alt="{{ 'gift_cards.issued.add_to_apple_wallet' | t | default: 'Add to Apple Wallet' }}">
      </a>
    {%- endif -%}

  </div>
</div>

{% schema %}
{
  "name": "Gift card",
  "settings": []
}
{% endschema %}
