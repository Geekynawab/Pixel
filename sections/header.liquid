<header class="site-header" role="banner">

  <!-- ── Announcement Bar ── -->
  <div class="announcement-bar" id="announcement-bar" data-interval="{{ section.settings.bar_interval }}" aria-live="polite">
    <div class="announcement-bar__track">
      {%- if section.settings.bar_message_1 != blank -%}
        <div class="announcement-bar__slide is-active">
          {%- if section.settings.bar_link_1 != blank -%}<a href="{{ section.settings.bar_link_1 }}">{{ section.settings.bar_message_1 }}</a>{%- else -%}<span>{{ section.settings.bar_message_1 }}</span>{%- endif -%}
        </div>
      {%- endif -%}
      {%- if section.settings.bar_message_2 != blank -%}
        <div class="announcement-bar__slide">
          {%- if section.settings.bar_link_2 != blank -%}<a href="{{ section.settings.bar_link_2 }}">{{ section.settings.bar_message_2 }}</a>{%- else -%}<span>{{ section.settings.bar_message_2 }}</span>{%- endif -%}
        </div>
      {%- endif -%}
      {%- if section.settings.bar_message_3 != blank -%}
        <div class="announcement-bar__slide">
          {%- if section.settings.bar_link_3 != blank -%}<a href="{{ section.settings.bar_link_3 }}">{{ section.settings.bar_message_3 }}</a>{%- else -%}<span>{{ section.settings.bar_message_3 }}</span>{%- endif -%}
        </div>
      {%- endif -%}
      {%- if section.settings.bar_message_4 != blank -%}
        <div class="announcement-bar__slide">
          {%- if section.settings.bar_link_4 != blank -%}<a href="{{ section.settings.bar_link_4 }}">{{ section.settings.bar_message_4 }}</a>{%- else -%}<span>{{ section.settings.bar_message_4 }}</span>{%- endif -%}
        </div>
      {%- endif -%}
      {%- if section.settings.bar_message_5 != blank -%}
        <div class="announcement-bar__slide">
          {%- if section.settings.bar_link_5 != blank -%}<a href="{{ section.settings.bar_link_5 }}">{{ section.settings.bar_message_5 }}</a>{%- else -%}<span>{{ section.settings.bar_message_5 }}</span>{%- endif -%}
        </div>
      {%- endif -%}
    </div>
  </div>

  <!-- ── Row 1: Logo bar ── -->
  <div class="header-logo-bar">
    <div class="container">
      <div class="header-logo-bar__inner">

        <!-- Left: hamburger (mobile) | search (desktop) -->
        <div class="header-logo-bar__left">
          <button class="hamburger header-mobile-only" id="hamburger-btn"
            aria-label="{{ 'accessibility.open_navigation' | t }}"
            aria-controls="mobile-nav" aria-expanded="false">
            <span></span><span></span><span></span>
          </button>
          <button class="header-icon header-desktop-only" id="search-toggle" aria-label="Search">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" aria-hidden="true">
              <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
            </svg>
          </button>
        </div>

        <!-- Center: Logo -->
        <a href="/" class="site-logo" aria-label="{{ shop.name }} — Home">
          {%- if section.settings.logo != blank -%}
            <img
              src="{{ section.settings.logo | image_url: width: section.settings.logo_width }}"
              alt="{{ shop.name }}"
              width="{{ section.settings.logo_width }}"
              loading="eager">
          {%- else -%}
            <span class="site-logo__text">{{ shop.name | upcase }}</span>
          {%- endif -%}
        </a>

        <!-- Right: account, wishlist, cart -->
        <div class="header-logo-bar__right">
          <a href="/account" class="header-icon" aria-label="Account">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" aria-hidden="true">
              <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
              <circle cx="12" cy="7" r="4"/>
            </svg>
          </a>
          <a href="/pages/wishlist" class="header-icon" aria-label="Wishlist">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" aria-hidden="true">
              <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
            </svg>
          </a>
          <button class="header-icon" data-cart-open aria-label="{{ 'accessibility.open_cart' | t }}" aria-expanded="false" style="position:relative;">
            {% render 'icon-cart' %}
            <span class="cart-count" aria-live="polite">{{ cart.item_count }}</span>
          </button>
        </div>

      </div>
    </div>
  </div>

  <!-- ── Row 2: Nav bar (desktop) ── -->
  <div class="header-nav-bar" id="header-nav-bar">
    <div class="container">
      <nav class="site-nav" aria-label="Main navigation">
        {%- for link in linklists[section.settings.menu].links -%}
          <div class="site-nav__item{% if link.links != blank %} site-nav__item--has-panel{% endif %}">
            {%- if link.links != blank -%}
              <button
                class="site-nav__link"
                data-nav-trigger="{{ forloop.index }}"
                aria-expanded="false"
                aria-haspopup="true"
                aria-controls="nav-panel-{{ forloop.index }}">
                {{ link.title }}
              </button>
            {%- else -%}
              <a href="{{ link.url }}" class="site-nav__link"{% if link.active %} aria-current="page"{% endif %}>
                {{ link.title }}
              </a>
            {%- endif -%}
          </div>
        {%- endfor -%}
      </nav>
    </div>

    <!-- Nav dropdown panels -->
    {%- for link in linklists[section.settings.menu].links -%}
      {%- if link.links != blank -%}
        {%- assign panel_block = nil -%}
        {%- for block in section.blocks -%}
          {%- if block.type == 'mega_menu_image' and block.settings.nav_title == link.title -%}
            {%- assign panel_block = block -%}
          {%- endif -%}
        {%- endfor -%}

        {%- if panel_block != nil -%}
          <!-- Image panel layout -->
          <div class="nav-panel nav-panel--images" id="nav-panel-{{ forloop.index }}" aria-hidden="true" role="region">
            <div class="container">
              <div class="nav-panel__inner">
                <div class="nav-panel__links nav-panel__links--col">
                  <a href="{{ link.url }}" class="nav-panel__link nav-panel__link--heading">View All</a>
                  {%- for child in link.links -%}
                    <a href="{{ child.url }}" class="nav-panel__link">{{ child.title }}</a>
                  {%- endfor -%}
                </div>
                <div class="nav-panel__img-grid">
                  {%- if panel_block.settings.image_1 != blank -%}
                    <a href="{{ panel_block.settings.link_1 | default: link.url }}" class="nav-panel__img-item">
                      <img src="{{ panel_block.settings.image_1 | image_url: width: 600 }}" alt="{{ panel_block.settings.label_1 | escape }}" loading="lazy" width="600">
                      {%- if panel_block.settings.label_1 != blank -%}
                        <p class="nav-panel__img-label">{{ panel_block.settings.label_1 | upcase }}</p>
                        <p class="nav-panel__img-sub">View All</p>
                      {%- endif -%}
                    </a>
                  {%- endif -%}
                  {%- if panel_block.settings.image_2 != blank -%}
                    <a href="{{ panel_block.settings.link_2 | default: link.url }}" class="nav-panel__img-item">
                      <img src="{{ panel_block.settings.image_2 | image_url: width: 600 }}" alt="{{ panel_block.settings.label_2 | escape }}" loading="lazy" width="600">
                      {%- if panel_block.settings.label_2 != blank -%}
                        <p class="nav-panel__img-label">{{ panel_block.settings.label_2 | upcase }}</p>
                        <p class="nav-panel__img-sub">View All</p>
                      {%- endif -%}
                    </a>
                  {%- endif -%}
                  {%- if panel_block.settings.image_3 != blank -%}
                    <a href="{{ panel_block.settings.link_3 | default: link.url }}" class="nav-panel__img-item">
                      <img src="{{ panel_block.settings.image_3 | image_url: width: 600 }}" alt="{{ panel_block.settings.label_3 | escape }}" loading="lazy" width="600">
                      {%- if panel_block.settings.label_3 != blank -%}
                        <p class="nav-panel__img-label">{{ panel_block.settings.label_3 | upcase }}</p>
                        <p class="nav-panel__img-sub">View All</p>
                      {%- endif -%}
                    </a>
                  {%- endif -%}
                </div>
              </div>
            </div>
          </div>
        {%- else -%}
          <!-- Text-only panel layout -->
          <div class="nav-panel" id="nav-panel-{{ forloop.index }}" aria-hidden="true" role="region">
            <div class="container">
              <div class="nav-panel__inner">
                <div class="nav-panel__featured">
                  <a href="{{ link.url }}" class="nav-panel__featured-link">{{ link.title }}</a>
                </div>
                <div class="nav-panel__divider" aria-hidden="true"></div>
                <div class="nav-panel__links">
                  {%- for child in link.links -%}
                    <a href="{{ child.url }}" class="nav-panel__link">{{ child.title }}</a>
                  {%- endfor -%}
                </div>
              </div>
            </div>
          </div>
        {%- endif -%}
      {%- endif -%}
    {%- endfor -%}
  </div>

  <!-- ── Inline header search with predictive results ── -->
  <div class="header-search" id="header-search" aria-hidden="true">
    <div class="container">
      <form action="/search" method="get" class="header-search__form" role="search">
        <input type="hidden" name="type" value="product">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
        </svg>
        <div class="header-search-wrap">
          <input
            type="search"
            name="q"
            id="header-search-input"
            class="header-search__input"
            placeholder="Search products..."
            autocomplete="off"
            aria-label="Search products"
            aria-expanded="false"
            aria-owns="predictive-search-results"
            aria-autocomplete="list"
            role="combobox">
          <div class="predictive-search" id="predictive-search-results" role="listbox" aria-label="Search suggestions"></div>
        </div>
        <button type="button" class="header-search__close" id="header-search-close" aria-label="Close search">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
          </svg>
        </button>
      </form>
    </div>
  </div>

  <!-- ── Mobile nav ── -->
  <div class="mobile-nav-overlay" id="mobile-nav-overlay" aria-hidden="true"></div>

  <nav class="mobile-nav" id="mobile-nav" aria-label="Site navigation">
    {%- for link in linklists[section.settings.menu].links -%}
      <div class="mobile-nav__item">
        {%- if link.links != blank -%}
          <button class="mobile-nav__link mobile-nav__toggle"
            data-mobile-toggle="mobile-sub-{{ forloop.index }}"
            aria-expanded="false">
            {{ link.title }}
            <span class="toggle-icon">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
            </span>
          </button>
          <div class="mobile-nav__sub" id="mobile-sub-{{ forloop.index }}">
            {%- for child in link.links -%}
              <a href="{{ child.url }}">{{ child.title }}</a>
            {%- endfor -%}
          </div>
        {%- else -%}
          <a href="{{ link.url }}" class="mobile-nav__link"{% if link.active %} aria-current="page"{% endif %}>{{ link.title }}</a>
        {%- endif -%}
      </div>
    {%- endfor -%}
    <div class="mobile-nav__item">
      <a href="/account" class="mobile-nav__link">Account</a>
    </div>
  </nav>

</header>

{% schema %}
{
  "name": "Header",
  "limit": 1,
  "settings": [
    {
      "type": "link_list",
      "id": "menu",
      "label": "Navigation menu",
      "default": "main-menu"
    },
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo image"
    },
    {
      "type": "range",
      "id": "logo_width",
      "label": "Logo width",
      "min": 50,
      "max": 240,
      "step": 5,
      "unit": "px",
      "default": 120
    },
    {
      "type": "checkbox",
      "id": "sticky",
      "label": "Sticky header",
      "default": true
    },
    {
      "type": "header",
      "content": "Announcement Bar"
    },
    {
      "type": "paragraph",
      "content": "Add up to 5 messages that cycle automatically."
    },
    {
      "type": "text",
      "id": "bar_message_1",
      "label": "Message 1",
      "default": "Import duties included in all shipping"
    },
    {
      "type": "url",
      "id": "bar_link_1",
      "label": "Message 1 link"
    },
    {
      "type": "text",
      "id": "bar_message_2",
      "label": "Message 2",
      "default": "New Season: Camp Maha Hardy Okinawa"
    },
    {
      "type": "url",
      "id": "bar_link_2",
      "label": "Message 2 link"
    },
    {
      "type": "text",
      "id": "bar_message_3",
      "label": "Message 3",
      "default": "New Drop: Spring/Summer 2026"
    },
    {
      "type": "url",
      "id": "bar_link_3",
      "label": "Message 3 link"
    },
    {
      "type": "text",
      "id": "bar_message_4",
      "label": "Message 4"
    },
    {
      "type": "url",
      "id": "bar_link_4",
      "label": "Message 4 link"
    },
    {
      "type": "text",
      "id": "bar_message_5",
      "label": "Message 5"
    },
    {
      "type": "url",
      "id": "bar_link_5",
      "label": "Message 5 link"
    },
    {
      "type": "range",
      "id": "bar_interval",
      "label": "Cycle speed (seconds)",
      "min": 2,
      "max": 10,
      "step": 1,
      "default": 4
    }
  ],
  "blocks": [
    {
      "type": "mega_menu_image",
      "name": "Mega menu images",
      "settings": [
        {
          "type": "paragraph",
          "content": "Enter the nav item title exactly as it appears in your menu (e.g. Accessories)."
        },
        {
          "type": "text",
          "id": "nav_title",
          "label": "Nav item title"
        },
        {
          "type": "image_picker",
          "id": "image_1",
          "label": "Image 1"
        },
        {
          "type": "text",
          "id": "label_1",
          "label": "Image 1 label"
        },
        {
          "type": "url",
          "id": "link_1",
          "label": "Image 1 link"
        },
        {
          "type": "image_picker",
          "id": "image_2",
          "label": "Image 2"
        },
        {
          "type": "text",
          "id": "label_2",
          "label": "Image 2 label"
        },
        {
          "type": "url",
          "id": "link_2",
          "label": "Image 2 link"
        },
        {
          "type": "image_picker",
          "id": "image_3",
          "label": "Image 3"
        },
        {
          "type": "text",
          "id": "label_3",
          "label": "Image 3 label"
        },
        {
          "type": "url",
          "id": "link_3",
          "label": "Image 3 link"
        }
      ]
    }
  ]
}
{% endschema %}
