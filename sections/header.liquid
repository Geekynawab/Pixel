<header class="site-header" role="banner">

  <!-- Top strip -->
  <div class="header-topstrip">
    <div class="container">
      <div class="header-topstrip__inner">

        <div class="header-topstrip__social">
          <a href="#" class="topstrip-social" aria-label="X">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.744l7.73-8.835L1.254 2.25H8.08l4.261 5.638 5.903-5.638zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
          </a>
          <a href="#" class="topstrip-social" aria-label="Instagram">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="2" width="20" height="20" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="1.2" fill="currentColor" stroke="none"/></svg>
          </a>
          <a href="#" class="topstrip-social" aria-label="Discord">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor"><path d="M20.317 4.37a19.791 19.791 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 12.64 12.64 0 0 0-.617-1.25.077.077 0 0 0-.079-.037A19.736 19.736 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.099 18.057c.002.022.015.043.036.055a19.9 19.9 0 0 0 5.993 3.03.078.078 0 0 0 .084-.028c.462-.63.874-1.295 1.226-1.995a.076.076 0 0 0-.041-.106 13.1 13.1 0 0 1-1.872-.892.077.077 0 0 1-.008-.128 10.2 10.2 0 0 0 .372-.292.074.074 0 0 1 .077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 0 1 .078.01c.12.098.246.198.373.292a.077.077 0 0 1-.006.127 12.299 12.299 0 0 1-1.873.892.077.077 0 0 0-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084.028 19.839 19.839 0 0 0 6.002-3.03.077.077 0 0 0 .032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.03z"/></svg>
          </a>
          <a href="#" class="topstrip-social" aria-label="TikTok">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor"><path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-2.88 2.5 2.89 2.89 0 0 1-2.89-2.89 2.89 2.89 0 0 1 2.89-2.89c.28 0 .54.04.79.1V9.01a6.33 6.33 0 0 0-.79-.05 6.34 6.34 0 0 0-6.34 6.34 6.34 6.34 0 0 0 6.34 6.34 6.34 6.34 0 0 0 6.33-6.34V8.95a8.16 8.16 0 0 0 4.77 1.52V7.03a4.85 4.85 0 0 1-1-.34z"/></svg>
          </a>
          <a href="#" class="topstrip-social" aria-label="YouTube">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
          </a>
        </div>

        <p class="header-topstrip__text">Free shipping on orders over $50 🎯</p>

        <div class="header-topstrip__right">
          <a href="/pages/contact" class="header-topstrip__help">
            <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
            HELP
          </a>
        </div>

      </div>
    </div>
  </div>

  <!-- Main header -->
  <div class="container">
    <div class="header-inner">

      <!-- Left: Hamburger + MENU label -->
      <div class="header-left">
        <button class="hamburger" id="hamburger-btn" aria-label="{{ 'accessibility.open_navigation' | t }}" aria-controls="mobile-nav" aria-expanded="false">
          <span></span><span></span><span></span>
        </button>
        <span class="header-menu-label">MENU</span>
      </div>

      <!-- Center: Logo -->
      <a href="/" class="site-logo" aria-label="{{ shop.name }} — Home">
        {%- if settings.logo != blank -%}
          <img
            src="{{ settings.logo | image_url: width: settings.logo_width }}"
            alt="{{ shop.name }}"
            width="{{ settings.logo_width }}"
            loading="eager">
        {%- else -%}
          <span class="site-logo__text">{{ settings.logo_text | default: 'KNIVES FACTORY' }}</span>
        {%- endif -%}
      </a>

      <!-- Right: Action icons -->
      <div class="header-actions">
        <button class="header-icon" id="search-toggle" aria-label="Search">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75">
            <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
          </svg>
        </button>
        <button class="header-icon" id="wishlist-icon" aria-label="Wishlist">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75">
            <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
          </svg>
          <span class="wishlist-count" id="wishlist-count" aria-live="polite"></span>
        </button>
        <a href="/account" class="header-icon" aria-label="Account">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75">
            <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
            <circle cx="12" cy="7" r="4"/>
          </svg>
        </a>
        <button class="header-icon" data-cart-open aria-label="{{ 'accessibility.open_cart' | t }}" aria-expanded="false">
          {% render 'icon-cart' %}
          <span class="cart-count" aria-live="polite">{{ cart.item_count }}</span>
        </button>
      </div>

    </div>
  </div>

  <!-- Nav drawer (hamburger opens this) -->
  <nav class="mobile-nav" id="mobile-nav" aria-label="Site navigation">

    <div class="mobile-nav__item">
      <button class="mobile-nav__link mobile-nav__toggle" data-mobile-toggle="mobile-sub-types">
        Shop by Type <span class="toggle-icon">+</span>
      </button>
      <div class="mobile-nav__sub" id="mobile-sub-types">
        <a href="/collections/keychains" class="mobile-nav__sub-link">🗝️ Keychains</a>
        <a href="/collections/toys" class="mobile-nav__sub-link">🧸 Toys</a>
        <a href="/collections/mousepads" class="mobile-nav__sub-link">🖱️ Mousepads</a>
      </div>
    </div>

    <div class="mobile-nav__item">
      <button class="mobile-nav__link mobile-nav__toggle" data-mobile-toggle="mobile-sub-collections">
        Collections <span class="toggle-icon">+</span>
      </button>
      <div class="mobile-nav__sub" id="mobile-sub-collections">
        <a href="/collections/prime" class="mobile-nav__sub-link">⚡ Prime Collection</a>
        <a href="/collections/reaver" class="mobile-nav__sub-link">💀 Reaver Collection</a>
        <a href="/collections/ion" class="mobile-nav__sub-link">🔵 Ion Collection</a>
      </div>
    </div>

    <div class="mobile-nav__item">
      <a href="/collections/all" class="mobile-nav__link">All Products</a>
    </div>

    <div class="mobile-nav__item">
      <a href="/pages/contact" class="mobile-nav__link">Contact</a>
    </div>

  </nav>

</header>

{% schema %}
{
  "name": "Header",
  "limit": 1,
  "settings": []
}
{% endschema %}
