<header class="site-header" role="banner">
  <div class="container">
    <div class="header-inner">

      <!-- Logo -->
      <a href="/" class="site-logo" aria-label="{{ shop.name }} — Home">
        {%- if settings.logo != blank -%}
          <img
            src="{{ settings.logo | image_url: width: settings.logo_width }}"
            alt="{{ shop.name }}"
            width="{{ settings.logo_width }}"
            loading="eager">
        {%- else -%}
          <span>{{ settings.logo_text | default: shop.name | upcase }}</span>
        {%- endif -%}
      </a>

      <!-- Primary navigation (desktop) -->
      <nav class="nav-primary" aria-label="Primary navigation">

        <!-- Shop by Type dropdown -->
        <div class="nav-item nav-item--dropdown">
          <button class="nav-link nav-dropdown-toggle" aria-expanded="false">
            Shop by Type
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="6 9 12 15 18 9"/></svg>
          </button>
          <div class="nav-dropdown">
            <a href="/collections/keychains" class="nav-dropdown__item">🗝️ Keychains</a>
            <a href="/collections/toys" class="nav-dropdown__item">🧸 Toys</a>
            <a href="/collections/mousepads" class="nav-dropdown__item">🖱️ Mousepads</a>
          </div>
        </div>

        <!-- Collections dropdown -->
        <div class="nav-item nav-item--dropdown">
          <button class="nav-link nav-dropdown-toggle" aria-expanded="false">
            Collections
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="6 9 12 15 18 9"/></svg>
          </button>
          <div class="nav-dropdown">
            <a href="/collections/prime" class="nav-dropdown__item">⚡ Prime Collection</a>
            <a href="/collections/reaver" class="nav-dropdown__item">💀 Reaver Collection</a>
            <a href="/collections/ion" class="nav-dropdown__item">🔵 Ion Collection</a>
          </div>
        </div>

      </nav>

      <!-- Header actions -->
      <div class="header-actions">

        <!-- Search -->
        <button class="header-icon" id="search-toggle" aria-label="Search">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75">
            <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
          </svg>
        </button>

        <!-- Wishlist -->
        <button class="header-icon" id="wishlist-icon" aria-label="Wishlist">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75">
            <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
          </svg>
          <span class="wishlist-count" id="wishlist-count" aria-live="polite"></span>
        </button>

        <!-- Account -->
        <a href="/account" class="header-icon" aria-label="Account">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75">
            <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
            <circle cx="12" cy="7" r="4"/>
          </svg>
        </a>

        <!-- Cart -->
        <button class="header-icon" data-cart-open aria-label="{{ 'accessibility.open_cart' | t }}" aria-expanded="false">
          {% render 'icon-cart' %}
          <span class="cart-count" aria-live="polite">{{ cart.item_count }}</span>
        </button>

        <!-- Hamburger (mobile) -->
        <button class="hamburger" id="hamburger-btn" aria-label="{{ 'accessibility.open_navigation' | t }}" aria-controls="mobile-nav" aria-expanded="false">
          <span></span><span></span><span></span>
        </button>

      </div>
    </div>
  </div>

  <!-- Mobile navigation -->
  <nav class="mobile-nav" id="mobile-nav" aria-label="Mobile navigation">

    <div class="mobile-nav__item">
      <button class="mobile-nav__link mobile-nav__toggle" data-mobile-toggle="mobile-sub-types">
        Shop by Type <span class="toggle-icon">+</span>
      </button>
      <div class="mobile-nav__sub" id="mobile-sub-types">
        <a href="/collections/keychains" class="mobile-nav__sub-link">🗝️ Keychains</a>
        <a href="/collections/toys" class="mobile-nav__sub-link">🧸 Toys</a>
        <a href="/collections/mousepads" class="mobile-nav__sub-link">🖱️ Mousepads</a>
      </div>
    </div>

    <div class="mobile-nav__item">
      <button class="mobile-nav__link mobile-nav__toggle" data-mobile-toggle="mobile-sub-collections">
        Collections <span class="toggle-icon">+</span>
      </button>
      <div class="mobile-nav__sub" id="mobile-sub-collections">
        <a href="/collections/prime" class="mobile-nav__sub-link">⚡ Prime Collection</a>
        <a href="/collections/reaver" class="mobile-nav__sub-link">💀 Reaver Collection</a>
        <a href="/collections/ion" class="mobile-nav__sub-link">🔵 Ion Collection</a>
      </div>
    </div>

  </nav>

</header>

{% schema %}
{
  "name": "Header",
  "limit": 1,
  "settings": []
}
{% endschema %}
