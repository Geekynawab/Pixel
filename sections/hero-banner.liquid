<section class="hero-split" id="hero-banner-{{ section.id }}">

  <!-- Left: main editorial image -->
  <div class="hero-split__main">
    {%- if section.settings.bg_image != blank -%}
      <img
        src="{{ section.settings.bg_image | image_url: width: 1600 }}"
        alt="{{ section.settings.bg_image.alt | escape }}"
        loading="eager"
        width="1600"
        height="1200">
    {%- else -%}
      {{ 'lifestyle-2' | placeholder_svg_tag: 'placeholder-svg' }}
    {%- endif -%}

    {%- if section.settings.eyebrow != blank or section.settings.heading != blank or section.settings.cta_label != blank -%}
      <div class="hero-split__overlay"></div>
      <div class="hero-split__content">
        {%- if section.settings.eyebrow != blank -%}
          <p class="hero-split__eyebrow">{{ section.settings.eyebrow }}</p>
        {%- endif -%}
        {%- if section.settings.heading != blank -%}
          <h1 class="hero-split__title">{{ section.settings.heading }}</h1>
        {%- endif -%}
        {%- if section.settings.cta_label != blank and section.settings.cta_link != blank -%}
          <div class="hero-split__actions">
            <a href="{{ section.settings.cta_link }}" class="btn btn--primary">
              {{ section.settings.cta_label }}
            </a>
          </div>
        {%- endif -%}
      </div>
    {%- endif -%}
  </div>

  <!-- Right: stack of up to 3 images -->
  <div class="hero-split__stack">
    {%- if section.settings.image_2 != blank -%}
      <div class="hero-split__stack-item">
        <img
          src="{{ section.settings.image_2 | image_url: width: 800 }}"
          alt="{{ section.settings.image_2.alt | escape }}"
          loading="eager"
          width="800"
          height="1000">
      </div>
    {%- else -%}
      <div class="hero-split__stack-item">{{ 'product-apparel-1' | placeholder_svg_tag: 'placeholder-svg' }}</div>
    {%- endif -%}
    {%- if section.settings.image_3 != blank -%}
      <div class="hero-split__stack-item">
        <img
          src="{{ section.settings.image_3 | image_url: width: 800 }}"
          alt="{{ section.settings.image_3.alt | escape }}"
          loading="lazy"
          width="800"
          height="1000">
      </div>
    {%- else -%}
      <div class="hero-split__stack-item">{{ 'product-apparel-2' | placeholder_svg_tag: 'placeholder-svg' }}</div>
    {%- endif -%}
    {%- if section.settings.image_4 != blank -%}
      <div class="hero-split__stack-item">
        <img
          src="{{ section.settings.image_4 | image_url: width: 800 }}"
          alt="{{ section.settings.image_4.alt | escape }}"
          loading="lazy"
          width="800"
          height="1000">
      </div>
    {%- endif -%}
  </div>

</section>

{% schema %}
{
  "name": "Hero Banner",
  "tag": "section",
  "class": "section-hero",
  "settings": [
    {
      "type": "image_picker",
      "id": "bg_image",
      "label": "Main image (left panel)"
    },
    {
      "type": "image_picker",
      "id": "image_2",
      "label": "Stack image 1 (top right)"
    },
    {
      "type": "image_picker",
      "id": "image_3",
      "label": "Stack image 2 (middle right)"
    },
    {
      "type": "image_picker",
      "id": "image_4",
      "label": "Stack image 3 (bottom right)"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text",
      "default": "New Collection"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Button text",
      "default": "Shop Now"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "Button link"
    }
  ],
  "presets": [
    {
      "name": "Hero Banner",
      "settings": {
        "eyebrow": "New Collection",
        "heading": "New Arrivals",
        "cta_label": "Shop Now"
      }
    }
  ]
}
{% endschema %}
