{%- paginate collection.products by 24 -%}

<!-- Collection toolbar -->
<div class="collection-toolbar">
  <div class="container">
    <div class="collection-toolbar__inner">
      <p class="collection-toolbar__title">{{ collection.title | upcase }}</p>
      <div class="collection-toolbar__right">
        <span class="collection-toolbar__count">{{ collection.products_count }}</span>
        <label for="sort-by" class="visually-hidden">{{ 'collections.sorting.title' | t }}</label>
        <select id="sort-by" class="collection-sort__select" onchange="window.location = window.location.pathname + '?sort_by=' + this.value">
          <option value="manual"{% if collection.sort_by == 'manual' %} selected{% endif %}>{{ 'collections.sorting.manual' | t }}</option>
          <option value="best-selling"{% if collection.sort_by == 'best-selling' %} selected{% endif %}>{{ 'collections.sorting.best_selling' | t }}</option>
          <option value="price-ascending"{% if collection.sort_by == 'price-ascending' %} selected{% endif %}>{{ 'collections.sorting.price_ascending' | t }}</option>
          <option value="price-descending"{% if collection.sort_by == 'price-descending' %} selected{% endif %}>{{ 'collections.sorting.price_descending' | t }}</option>
          <option value="title-ascending"{% if collection.sort_by == 'title-ascending' %} selected{% endif %}>{{ 'collections.sorting.title_ascending' | t }}</option>
          <option value="title-descending"{% if collection.sort_by == 'title-descending' %} selected{% endif %}>{{ 'collections.sorting.title_descending' | t }}</option>
          <option value="created-descending"{% if collection.sort_by == 'created-descending' %} selected{% endif %}>{{ 'collections.sorting.created_descending' | t }}</option>
        </select>
      </div>
    </div>
  </div>
</div>

<!-- Product grid -->
<div class="container collection-grid-container">

  {%- if collection.filters.size > 0 -%}
    {%- assign active_count = 0 -%}
    {%- for filter in collection.filters -%}
      {%- for v in filter.active_values -%}{%- assign active_count = active_count | plus: 1 -%}{%- endfor -%}
    {%- endfor -%}
    {%- if active_count > 0 -%}
      <div class="active-filters">
        {%- for filter in collection.filters -%}
          {%- for v in filter.active_values -%}
            <a href="{{ v.url_to_remove }}" class="active-filter-tag">
              {{ filter.label }}: {{ v.label }}
              <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
            </a>
          {%- endfor -%}
        {%- endfor -%}
        <a href="{{ collection.url }}" class="active-filter-clear">Clear all</a>
      </div>
    {%- endif -%}
  {%- endif -%}

  <div class="product-grid">
    {%- for product in collection.products -%}
      {% render 'product-card', product: product %}
    {%- else -%}
      <p class="collection-empty">No products found.</p>
    {%- endfor -%}
  </div>

  {%- if paginate.pages > 1 -%}
    <div class="collection-pagination">
      {%- if paginate.previous -%}
        <a href="{{ paginate.previous.url }}" class="btn btn--ghost btn--sm">{{ 'general.pagination.previous' | t }}</a>
      {%- endif -%}
      {%- for part in paginate.parts -%}
        {%- if part.is_link -%}
          <a href="{{ part.url }}" class="btn btn--ghost btn--sm">{{ part.title }}</a>
        {%- else -%}
          <span class="btn btn--primary btn--sm" aria-current="page">{{ part.title }}</span>
        {%- endif -%}
      {%- endfor -%}
      {%- if paginate.next -%}
        <a href="{{ paginate.next.url }}" class="btn btn--ghost btn--sm">{{ 'general.pagination.next' | t }}</a>
      {%- endif -%}
    </div>
  {%- endif -%}

</div>

{%- endpaginate -%}

{% schema %}
{
  "name": "Collection",
  "settings": []
}
{% endschema %}
