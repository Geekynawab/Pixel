<div class="section">
  <div class="container">

    <div style="display:grid;grid-template-columns:240px 1fr;gap:2rem;align-items:start;">

      <!-- Sidebar -->
      <aside style="background:var(--color-bg-card);border:1px solid var(--color-border);padding:1.5rem;">
        <p style="font-size:0.8rem;color:var(--color-text-secondary);margin-bottom:0.25rem;letter-spacing:0.08em;">SIGNED IN AS</p>
        <p style="font-weight:700;margin-bottom:1.5rem;">{{ customer.email }}</p>
        <nav aria-label="Account navigation">
          <a href="/account" style="display:block;padding:0.5rem 0;color:var(--color-text-primary);font-size:0.88rem;border-bottom:1px solid var(--color-border);">{{ 'customer.account.title' | t }}</a>
          <a href="/account/addresses" style="display:block;padding:0.5rem 0;color:var(--color-text-primary);font-size:0.88rem;border-bottom:1px solid var(--color-border);">{{ 'customer.addresses.title' | t }}</a>
          <a href="/account/logout" style="display:block;padding:0.5rem 0;color:var(--color-accent);font-size:0.88rem;">Sign out</a>
        </nav>
      </aside>

      <!-- Content -->
      <div>
        <h1 class="section-title" style="margin-bottom:2rem;">{{ 'customer.orders.title' | t }}</h1>

        {%- if customer.orders.size > 0 -%}
          <table style="width:100%;border-collapse:collapse;font-size:0.88rem;">
            <thead>
              <tr style="border-bottom:1px solid var(--color-border);text-align:left;">
                <th style="padding:0.75rem 0.5rem;color:var(--color-text-secondary);font-weight:600;letter-spacing:0.06em;">Order</th>
                <th style="padding:0.75rem 0.5rem;color:var(--color-text-secondary);font-weight:600;letter-spacing:0.06em;">{{ 'customer.orders.date' | t }}</th>
                <th style="padding:0.75rem 0.5rem;color:var(--color-text-secondary);font-weight:600;letter-spacing:0.06em;">{{ 'customer.orders.payment_status' | t }}</th>
                <th style="padding:0.75rem 0.5rem;color:var(--color-text-secondary);font-weight:600;letter-spacing:0.06em;">{{ 'customer.orders.fulfillment_status' | t }}</th>
                <th style="padding:0.75rem 0.5rem;color:var(--color-text-secondary);font-weight:600;letter-spacing:0.06em;">{{ 'customer.orders.total' | t }}</th>
              </tr>
            </thead>
            <tbody>
              {%- for order in customer.orders -%}
                <tr style="border-bottom:1px solid var(--color-border);">
                  <td style="padding:0.75rem 0.5rem;">
                    <a href="{{ order.customer_url }}" style="color:var(--color-accent);">{{ order.name }}</a>
                  </td>
                  <td style="padding:0.75rem 0.5rem;color:var(--color-text-secondary);">{{ order.created_at | time_tag: format: 'date' }}</td>
                  <td style="padding:0.75rem 0.5rem;">{{ order.financial_status_label }}</td>
                  <td style="padding:0.75rem 0.5rem;">{{ order.fulfillment_status_label }}</td>
                  <td style="padding:0.75rem 0.5rem;font-weight:700;">{{ order.total_price | money }}</td>
                </tr>
              {%- endfor -%}
            </tbody>
          </table>
        {%- else -%}
          <p style="color:var(--color-text-muted);">{{ 'customer.orders.none' | t }}</p>
          <a href="/collections/all" class="btn btn--primary" style="margin-top:1.5rem;display:inline-flex;">Start Shopping</a>
        {%- endif -%}
      </div>

    </div>
  </div>
</div>

{% schema %}
{
  "name": "Account",
  "settings": []
}
{% endschema %}
