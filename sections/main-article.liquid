<article class="article-page">

  <!-- Full-bleed hero -->
  {%- if article.image -%}
    <div class="article-hero">
      <img
        src="{{ article.image | image_url: width: 2000 }}"
        alt="{{ article.image.alt | default: article.title | escape }}"
        class="article-hero__img"
        loading="eager"
        width="2000">
      <div class="article-hero__overlay"></div>
      <div class="article-hero__content container">
        {%- if article.tags.size > 0 -%}
          <p class="article-hero__tag">{{ article.tags | join: ' · ' | upcase }}</p>
        {%- endif -%}
        <h1 class="article-hero__title">{{ article.title }}</h1>
        <p class="article-hero__meta">{{ article.published_at | date: '%d.%m.%Y' }}</p>
      </div>
    </div>
  {%- else -%}
    <div class="article-title-block container">
      {%- if article.tags.size > 0 -%}
        <p class="article-hero__tag" style="color:var(--color-text-muted);">{{ article.tags | join: ' · ' | upcase }}</p>
      {%- endif -%}
      <h1>{{ article.title }}</h1>
      <p class="article-hero__meta" style="color:var(--color-text-muted);">{{ article.published_at | date: '%d.%m.%Y' }}</p>
    </div>
  {%- endif -%}

  <!-- Article body -->
  <div class="container">
    <div class="article-body">
      {{ article.content }}
    </div>

    <!-- Back to journal -->
    <div class="article-back">
      <a href="{{ blog.url }}" class="article-back__link">← {{ blog.title | upcase }}</a>
    </div>
  </div>

  <!-- Comments -->
  {%- if blog.comments_enabled? -%}
    <div class="container">
      <div class="article-comments">
        {%- if article.comments_count > 0 -%}
          <h2 class="article-comments__heading">{{ article.comments_count }} Comments</h2>
          {%- for comment in article.comments -%}
            <div class="article-comment">
              <p class="article-comment__meta">{{ comment.author }} · {{ comment.created_at | date: '%d.%m.%Y' }}</p>
              <p class="article-comment__body">{{ comment.content }}</p>
            </div>
          {%- endfor -%}
        {%- endif -%}

        {% form 'new_comment', article %}
          <h3 class="article-comments__heading" style="margin-top:2.5rem;">Leave a Comment</h3>
          <div class="article-comment-form">
            <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem;margin-bottom:1rem;">
              <input type="text" name="comment[author]" placeholder="Name" required class="article-input">
              <input type="email" name="comment[email]" placeholder="Email" required class="article-input">
            </div>
            <textarea name="comment[body]" rows="4" placeholder="Your comment" required class="article-input" style="width:100%;resize:vertical;margin-bottom:1rem;"></textarea>
            <button type="submit" class="btn btn--primary">Post Comment</button>
          </div>
        {% endform %}
      </div>
    </div>
  {%- endif -%}

</article>

{% schema %}
{
  "name": "Article",
  "settings": []
}
{% endschema %}
