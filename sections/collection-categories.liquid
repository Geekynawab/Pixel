<section class="collection-spotlight" id="collection-spotlight-{{ section.id }}">

  {%- if section.settings.bg_image != blank -%}
    <div class="collection-spotlight__bg">
      <img
        src="{{ section.settings.bg_image | image_url: width: 2000 }}"
        alt=""
        loading="lazy"
        width="2000"
        height="1200">
    </div>
  {%- endif -%}

  <div class="collection-spotlight__inner">
    {%- if section.settings.label != blank -%}
      <p class="collection-spotlight__label">{{ section.settings.label }}</p>
    {%- endif -%}

    {%- if section.settings.logo != blank -%}
      <img
        src="{{ section.settings.logo | image_url: width: 300 }}"
        alt="{{ section.settings.heading }}"
        class="collection-spotlight__logo"
        loading="lazy"
        width="300">
    {%- endif -%}

    {%- if section.settings.heading != blank -%}
      <h2 class="collection-spotlight__title">{{ section.settings.heading }}</h2>
    {%- endif -%}

    {%- if section.settings.subheading != blank -%}
      <p class="collection-spotlight__sub">{{ section.settings.subheading }}</p>
    {%- endif -%}

    {%- if section.settings.cta_label != blank and section.settings.cta_link != blank -%}
      <a href="{{ section.settings.cta_link }}" class="btn btn--spotlight">
        {{ section.settings.cta_label }}
      </a>
    {%- endif -%}
  </div>

</section>

{% schema %}
{
  "name": "Collection Spotlight",
  "tag": "section",
  "settings": [
    {
      "type": "image_picker",
      "id": "bg_image",
      "label": "Background image"
    },
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo / icon (optional, shown white)"
    },
    {
      "type": "text",
      "id": "label",
      "label": "Eyebrow label",
      "default": "Featured Collection"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "New Season"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Button text",
      "default": "Shop the Collection"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "Button link"
    }
  ],
  "presets": [
    {
      "name": "Collection Spotlight",
      "settings": {
        "label": "Featured Collection",
        "heading": "New Season",
        "cta_label": "Shop the Collection"
      }
    }
  ]
}
{% endschema %}
