<div class="journal-page">
  <div class="container">

    <div class="journal-header">
      <h1 class="journal-header__title">{{ blog.title | upcase }}</h1>
    </div>

    {%- paginate blog.articles by 12 -%}
      <div class="journal-grid">
        {%- for article in blog.articles -%}
          <article class="journal-card">
            <a href="{{ article.url }}" class="journal-card__media" tabindex="-1" aria-hidden="true">
              {%- if article.image -%}
                <img
                  src="{{ article.image | image_url: width: 900 }}"
                  alt="{{ article.image.alt | default: article.title | escape }}"
                  width="900"
                  loading="{% if forloop.index <= 4 %}eager{% else %}lazy{% endif %}">
              {%- else -%}
                {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg journal-card__placeholder' }}
              {%- endif -%}
            </a>
            <div class="journal-card__info">
              {%- if article.tags.size > 0 -%}
                <p class="journal-card__tag">{{ article.tags.first | upcase }}</p>
              {%- endif -%}
              <h2 class="journal-card__title">
                <a href="{{ article.url }}">{{ article.title }}</a>
              </h2>
              <p class="journal-card__date">{{ article.published_at | date: '%d.%m.%Y' }}</p>
            </div>
          </article>
        {%- else -%}
          <p style="color:var(--color-text-muted);padding:3rem 0;">No journal entries yet.</p>
        {%- endfor -%}
      </div>

      {%- if paginate.pages > 1 -%}
        <div class="collection-pagination">
          {%- if paginate.previous -%}
            <a href="{{ paginate.previous.url }}" class="btn btn--ghost btn--sm">{{ 'general.pagination.previous' | t }}</a>
          {%- endif -%}
          {%- if paginate.next -%}
            <a href="{{ paginate.next.url }}" class="btn btn--ghost btn--sm">{{ 'general.pagination.next' | t }}</a>
          {%- endif -%}
        </div>
      {%- endif -%}
    {%- endpaginate -%}

  </div>
</div>

{% schema %}
{
  "name": "Blog",
  "settings": []
}
{% endschema %}
