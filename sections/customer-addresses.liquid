<div class="section">
  <div class="container">

    <div style="display:grid;grid-template-columns:240px 1fr;gap:2rem;align-items:start;">

      <!-- Sidebar -->
      <aside style="background:var(--color-bg-card);border:1px solid var(--color-border);padding:1.5rem;">
        <p style="font-size:0.8rem;color:var(--color-text-secondary);margin-bottom:0.25rem;letter-spacing:0.08em;">SIGNED IN AS</p>
        <p style="font-weight:700;margin-bottom:1.5rem;">{{ customer.email }}</p>
        <nav aria-label="Account navigation">
          <a href="/account" style="display:block;padding:0.5rem 0;color:var(--color-text-primary);font-size:0.88rem;border-bottom:1px solid var(--color-border);">{{ 'customer.account.title' | t }}</a>
          <a href="/account/addresses" style="display:block;padding:0.5rem 0;color:var(--color-accent);font-size:0.88rem;border-bottom:1px solid var(--color-border);">{{ 'customer.addresses.title' | t }}</a>
          <a href="/account/logout" style="display:block;padding:0.5rem 0;color:var(--color-accent);font-size:0.88rem;">Sign out</a>
        </nav>
      </aside>

      <!-- Addresses -->
      <div>
        <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:2rem;">
          <h1 class="section-title" style="margin:0;">{{ 'customer.addresses.title' | t }}</h1>
          <button class="btn btn--outline btn--sm" id="add-address-toggle" aria-expanded="false" aria-controls="new-address-form">+ Add address</button>
        </div>

        <!-- New address form (hidden by default) -->
        <div id="new-address-form" style="display:none;background:var(--color-bg-card);border:1px solid var(--color-border);padding:1.5rem;margin-bottom:2rem;">
          <h2 style="font-size:0.9rem;letter-spacing:0.08em;margin-bottom:1.25rem;">New address</h2>
          {%- form 'customer_address', customer.new_address -%}
            {%- render 'address-fields' -%}
            <button type="submit" class="btn btn--primary" style="margin-top:1rem;">Save address</button>
          {%- endform -%}
        </div>

        <!-- Existing addresses -->
        {%- if customer.addresses_count > 0 -%}
          {%- for address in customer.addresses -%}
            <div style="background:var(--color-bg-card);border:1px solid var(--color-border);padding:1.25rem;margin-bottom:1rem;position:relative;">
              {%- if address == customer.default_address -%}
                <span style="font-size:0.72rem;background:var(--color-accent);color:#fff;padding:0.2rem 0.5rem;letter-spacing:0.06em;position:absolute;top:1rem;right:1rem;">{{ 'customer.addresses.default' | t }}</span>
              {%- endif -%}
              <address style="font-style:normal;font-size:0.88rem;line-height:1.7;color:var(--color-text-secondary);">
                <strong style="color:var(--color-text-primary);">{{ address.name }}</strong><br>
                {{ address.address1 }}<br>
                {%- if address.address2 != blank -%}{{ address.address2 }}<br>{%- endif -%}
                {{ address.city }}, {{ address.province_code }} {{ address.zip }}<br>
                {{ address.country }}
              </address>
              <div style="display:flex;gap:0.75rem;margin-top:1rem;">
                <button class="btn btn--ghost btn--sm" onclick="document.getElementById('edit-address-{{ address.id }}').style.display='block';this.closest('div').style.display='none'">Edit</button>
                {%- form 'customer_address', address -%}
                  <input type="hidden" name="_method" value="delete">
                  <button type="submit" class="btn btn--ghost btn--sm" style="color:var(--color-accent);" onclick="return confirm('Delete this address?')">Delete</button>
                {%- endform -%}
                {%- unless address == customer.default_address -%}
                  {%- form 'customer_address', address -%}
                    <input type="hidden" name="_method" value="put">
                    <input type="hidden" name="address[default]" value="true">
                    <button type="submit" class="btn btn--ghost btn--sm">Set as default</button>
                  {%- endform -%}
                {%- endunless -%}
              </div>
            </div>

            <!-- Edit form (inline, hidden) -->
            <div id="edit-address-{{ address.id }}" style="display:none;background:var(--color-bg-card);border:1px solid var(--color-border);padding:1.5rem;margin-bottom:1rem;">
              <h2 style="font-size:0.9rem;letter-spacing:0.08em;margin-bottom:1.25rem;">Edit address</h2>
              {%- form 'customer_address', address -%}
                <input type="hidden" name="_method" value="put">
                <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem;margin-bottom:1rem;">
                  <div>
                    <label style="display:block;font-size:0.78rem;letter-spacing:0.06em;margin-bottom:0.3rem;color:var(--color-text-secondary);">First name</label>
                    <input type="text" name="address[first_name]" value="{{ address.first_name }}" autocomplete="given-name"
                      style="width:100%;background:var(--color-bg-primary);border:1px solid var(--color-border);color:var(--color-text-primary);padding:0.6rem 0.75rem;font-size:0.88rem;outline:none;">
                  </div>
                  <div>
                    <label style="display:block;font-size:0.78rem;letter-spacing:0.06em;margin-bottom:0.3rem;color:var(--color-text-secondary);">Last name</label>
                    <input type="text" name="address[last_name]" value="{{ address.last_name }}" autocomplete="family-name"
                      style="width:100%;background:var(--color-bg-primary);border:1px solid var(--color-border);color:var(--color-text-primary);padding:0.6rem 0.75rem;font-size:0.88rem;outline:none;">
                  </div>
                </div>
                <div style="margin-bottom:1rem;">
                  <label style="display:block;font-size:0.78rem;letter-spacing:0.06em;margin-bottom:0.3rem;color:var(--color-text-secondary);">Address</label>
                  <input type="text" name="address[address1]" value="{{ address.address1 }}" autocomplete="address-line1"
                    style="width:100%;background:var(--color-bg-primary);border:1px solid var(--color-border);color:var(--color-text-primary);padding:0.6rem 0.75rem;font-size:0.88rem;outline:none;">
                </div>
                <div style="margin-bottom:1rem;">
                  <label style="display:block;font-size:0.78rem;letter-spacing:0.06em;margin-bottom:0.3rem;color:var(--color-text-secondary);">Apartment, suite, etc.</label>
                  <input type="text" name="address[address2]" value="{{ address.address2 }}" autocomplete="address-line2"
                    style="width:100%;background:var(--color-bg-primary);border:1px solid var(--color-border);color:var(--color-text-primary);padding:0.6rem 0.75rem;font-size:0.88rem;outline:none;">
                </div>
                <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:1rem;margin-bottom:1rem;">
                  <div>
                    <label style="display:block;font-size:0.78rem;letter-spacing:0.06em;margin-bottom:0.3rem;color:var(--color-text-secondary);">City</label>
                    <input type="text" name="address[city]" value="{{ address.city }}" autocomplete="address-level2"
                      style="width:100%;background:var(--color-bg-primary);border:1px solid var(--color-border);color:var(--color-text-primary);padding:0.6rem 0.75rem;font-size:0.88rem;outline:none;">
                  </div>
                  <div>
                    <label style="display:block;font-size:0.78rem;letter-spacing:0.06em;margin-bottom:0.3rem;color:var(--color-text-secondary);">ZIP / Postal code</label>
                    <input type="text" name="address[zip]" value="{{ address.zip }}" autocomplete="postal-code"
                      style="width:100%;background:var(--color-bg-primary);border:1px solid var(--color-border);color:var(--color-text-primary);padding:0.6rem 0.75rem;font-size:0.88rem;outline:none;">
                  </div>
                  <div>
                    <label style="display:block;font-size:0.78rem;letter-spacing:0.06em;margin-bottom:0.3rem;color:var(--color-text-secondary);">Country</label>
                    {{ address.country_selector_tag: 'address[country]', class: '', style: 'width:100%;background:var(--color-bg-primary);border:1px solid var(--color-border);color:var(--color-text-primary);padding:0.6rem 0.75rem;font-size:0.88rem;outline:none;' }}
                  </div>
                </div>
                <div style="display:flex;gap:0.75rem;">
                  <button type="submit" class="btn btn--primary btn--sm">Update address</button>
                  <button type="button" class="btn btn--ghost btn--sm" onclick="document.getElementById('edit-address-{{ address.id }}').style.display='none'">Cancel</button>
                </div>
              {%- endform -%}
            </div>
          {%- endfor -%}
        {%- else -%}
          <p style="color:var(--color-text-muted);">No saved addresses yet.</p>
        {%- endif -%}
      </div>

    </div>
  </div>
</div>

<script>
  document.getElementById('add-address-toggle').addEventListener('click', function() {
    var form = document.getElementById('new-address-form');
    var open = form.style.display === 'block';
    form.style.display = open ? 'none' : 'block';
    this.setAttribute('aria-expanded', !open);
  });
</script>

{% schema %}
{
  "name": "Addresses",
  "settings": []
}
{% endschema %}
