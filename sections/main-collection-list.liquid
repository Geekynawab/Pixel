<div class="section">
  <div class="container">

    <h1 class="section-title" style="margin-bottom:0.5rem;">{{ 'collections.general.title' | t | default: 'All Collections' }}</h1>
    <p class="section-subtitle" style="margin-bottom:2.5rem;">{{ collections.size }} collections</p>

    <div class="product-grid">
      {%- for collection in collections -%}
        <a href="{{ collection.url }}" class="collection-card" style="display:block;position:relative;overflow:hidden;background:var(--color-bg-card);border:1px solid var(--color-border);text-decoration:none;">
          {%- if collection.image -%}
            <img
              src="{{ collection.image | image_url: width: 600 }}"
              srcset="{{ collection.image | image_url: width: 400 }} 400w, {{ collection.image | image_url: width: 600 }} 600w"
              sizes="(max-width:600px) 100vw, (max-width:1024px) 50vw, 25vw"
              alt="{{ collection.title | escape }}"
              loading="lazy"
              width="{{ collection.image.width }}"
              height="{{ collection.image.height }}"
              style="width:100%;aspect-ratio:1/1;object-fit:cover;display:block;transition:transform 0.3s ease;">
          {%- else -%}
            <div style="aspect-ratio:1/1;background:var(--color-bg-secondary);display:flex;align-items:center;justify-content:center;">
              {{ 'collection-1' | placeholder_svg_tag }}
            </div>
          {%- endif -%}
          <div style="position:absolute;bottom:0;left:0;right:0;padding:1rem;background:linear-gradient(transparent,rgba(0,0,0,0.8));">
            <h2 style="font-size:0.9rem;color:#fff;margin:0;">{{ collection.title }}</h2>
            <p style="font-size:0.75rem;color:rgba(255,255,255,0.7);margin:0.25rem 0 0;">{{ collection.products_count }} products</p>
          </div>
        </a>
      {%- endfor -%}
    </div>

  </div>
</div>

{% schema %}
{
  "name": "Collections list",
  "settings": []
}
{% endschema %}
