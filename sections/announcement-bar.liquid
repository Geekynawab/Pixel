{%- assign has_messages = false -%}
{%- for i in (1..5) -%}
  {%- assign key = 'message_' | append: i -%}
  {%- if section.settings[key] != blank -%}{%- assign has_messages = true -%}{%- endif -%}
{%- endfor -%}

{%- if has_messages -%}
<div class="announcement-bar" id="announcement-bar" data-interval="{{ section.settings.interval }}" aria-live="polite" aria-atomic="true">

  <div class="announcement-bar__track">
    {%- for i in (1..5) -%}
      {%- assign msg_key = 'message_' | append: i -%}
      {%- assign link_key = 'link_' | append: i -%}
      {%- if section.settings[msg_key] != blank -%}
        <div class="announcement-bar__slide{% if forloop.first %} is-active{% endif %}">
          {%- if section.settings[link_key] != blank -%}
            <a href="{{ section.settings[link_key] }}">{{ section.settings[msg_key] }}</a>
          {%- else -%}
            <span>{{ section.settings[msg_key] }}</span>
          {%- endif -%}
        </div>
      {%- endif -%}
    {%- endfor -%}
  </div>

  <button class="announcement-bar__close" aria-label="Dismiss announcement">
    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
      <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
    </svg>
  </button>

</div>
{%- endif -%}

{% schema %}
{
  "name": "Announcement Bar",
  "limit": 1,
  "settings": [
    {
      "type": "paragraph",
      "content": "Add up to 5 messages. They cycle automatically every 4 seconds."
    },
    {
      "type": "text",
      "id": "message_1",
      "label": "Message 1",
      "default": "Import duties included in all shipping"
    },
    {
      "type": "url",
      "id": "link_1",
      "label": "Message 1 link"
    },
    {
      "type": "text",
      "id": "message_2",
      "label": "Message 2",
      "default": "New Season: Camp Maha Hardy Okinawa"
    },
    {
      "type": "url",
      "id": "link_2",
      "label": "Message 2 link"
    },
    {
      "type": "text",
      "id": "message_3",
      "label": "Message 3",
      "default": "New Drop: Spring/Summer 2026"
    },
    {
      "type": "url",
      "id": "link_3",
      "label": "Message 3 link"
    },
    {
      "type": "text",
      "id": "message_4",
      "label": "Message 4"
    },
    {
      "type": "url",
      "id": "link_4",
      "label": "Message 4 link"
    },
    {
      "type": "text",
      "id": "message_5",
      "label": "Message 5"
    },
    {
      "type": "url",
      "id": "link_5",
      "label": "Message 5 link"
    },
    {
      "type": "range",
      "id": "interval",
      "label": "Cycle interval (seconds)",
      "min": 2,
      "max": 10,
      "step": 1,
      "default": 4
    }
  ]
}
{% endschema %}
