<div class="announcement-bar" id="announcement-bar" data-interval="{{ section.settings.interval }}" aria-live="polite">

  <div class="announcement-bar__track">

    {%- if section.settings.message_1 != blank -%}
      <div class="announcement-bar__slide is-active">
        {%- if section.settings.link_1 != blank -%}<a href="{{ section.settings.link_1 }}">{{ section.settings.message_1 }}</a>{%- else -%}<span>{{ section.settings.message_1 }}</span>{%- endif -%}
      </div>
    {%- endif -%}

    {%- if section.settings.message_2 != blank -%}
      <div class="announcement-bar__slide">
        {%- if section.settings.link_2 != blank -%}<a href="{{ section.settings.link_2 }}">{{ section.settings.message_2 }}</a>{%- else -%}<span>{{ section.settings.message_2 }}</span>{%- endif -%}
      </div>
    {%- endif -%}

    {%- if section.settings.message_3 != blank -%}
      <div class="announcement-bar__slide">
        {%- if section.settings.link_3 != blank -%}<a href="{{ section.settings.link_3 }}">{{ section.settings.message_3 }}</a>{%- else -%}<span>{{ section.settings.message_3 }}</span>{%- endif -%}
      </div>
    {%- endif -%}

    {%- if section.settings.message_4 != blank -%}
      <div class="announcement-bar__slide">
        {%- if section.settings.link_4 != blank -%}<a href="{{ section.settings.link_4 }}">{{ section.settings.message_4 }}</a>{%- else -%}<span>{{ section.settings.message_4 }}</span>{%- endif -%}
      </div>
    {%- endif -%}

    {%- if section.settings.message_5 != blank -%}
      <div class="announcement-bar__slide">
        {%- if section.settings.link_5 != blank -%}<a href="{{ section.settings.link_5 }}">{{ section.settings.message_5 }}</a>{%- else -%}<span>{{ section.settings.message_5 }}</span>{%- endif -%}
      </div>
    {%- endif -%}

  </div>

  <button class="announcement-bar__close" aria-label="Dismiss announcement">
    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
      <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
    </svg>
  </button>

</div>

{% schema %}
{
  "name": "Announcement Bar",
  "limit": 1,
  "settings": [
    {
      "type": "paragraph",
      "content": "Add up to 5 messages. They cycle automatically."
    },
    {
      "type": "text",
      "id": "message_1",
      "label": "Message 1",
      "default": "Import duties included in all shipping"
    },
    {
      "type": "url",
      "id": "link_1",
      "label": "Message 1 link"
    },
    {
      "type": "text",
      "id": "message_2",
      "label": "Message 2",
      "default": "New Season: Camp Maha Hardy Okinawa"
    },
    {
      "type": "url",
      "id": "link_2",
      "label": "Message 2 link"
    },
    {
      "type": "text",
      "id": "message_3",
      "label": "Message 3",
      "default": "New Drop: Spring/Summer 2026"
    },
    {
      "type": "url",
      "id": "link_3",
      "label": "Message 3 link"
    },
    {
      "type": "text",
      "id": "message_4",
      "label": "Message 4"
    },
    {
      "type": "url",
      "id": "link_4",
      "label": "Message 4 link"
    },
    {
      "type": "text",
      "id": "message_5",
      "label": "Message 5"
    },
    {
      "type": "url",
      "id": "link_5",
      "label": "Message 5 link"
    },
    {
      "type": "range",
      "id": "interval",
      "label": "Cycle interval (seconds)",
      "min": 2,
      "max": 10,
      "step": 1,
      "default": 4
    }
  ]
}
{% endschema %}
