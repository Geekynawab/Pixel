{%- assign current_variant = product.selected_or_first_available_variant -%}

<!-- Sticky ATC bar -->
<div class="sticky-atc" id="sticky-atc" aria-hidden="true">
  <div class="container">
    <div class="sticky-atc__inner">
      <div class="sticky-atc__info">
        {%- if product.featured_image -%}
          <img src="{{ product.featured_image | image_url: width: 80 }}" alt="{{ product.title | escape }}" width="40" height="40" class="sticky-atc__img">
        {%- endif -%}
        <div class="sticky-atc__text">
          <span class="sticky-atc__title">{{ product.title }}</span>
          <span class="sticky-atc__price" id="sticky-atc-price">
            {%- render 'price', product: product, variant: current_variant -%}
          </span>
        </div>
      </div>
      <button class="btn btn--primary sticky-atc__btn" id="sticky-atc-btn"
        {%- unless current_variant.available %} disabled{%- endunless -%}>
        {%- if current_variant.available -%}{{ 'products.product.add_to_cart' | t }}{%- else -%}{{ 'products.product.sold_out' | t }}{%- endif -%}
      </button>
    </div>
  </div>
</div>

<!-- Main product layout -->
<div class="product-page">
  <div class="container">
    <div class="product-layout">

      <!-- LEFT: Sticky gallery -->
      <div class="product-layout__gallery">
        <div class="product-gallery{% if product.media.size <= 1 %} product-gallery--single{% endif %}">

          {%- if product.media.size > 1 -%}
            <div class="product-gallery__thumbs">
              {%- for media in product.media limit: 8 -%}
                <button
                  class="product-gallery__thumb{% if forloop.first %} active{% endif %}"
                  data-media-id="{{ media.id }}"
                  data-media-type="{{ media.media_type }}"
                  {%- if media.media_type == 'image' -%}
                    data-src="{{ media | image_url: width: 900 }}"
                  {%- endif -%}
                  aria-label="View media {{ forloop.index }}">
                  {%- if media.media_type == 'image' -%}
                    <img
                      src="{{ media | image_url: width: 120 }}"
                      alt="{{ media.alt | default: product.title | escape }}"
                      width="120" height="120" loading="lazy">
                  {%- elsif media.media_type == 'video' or media.media_type == 'external_video' -%}
                    <div style="width:120px;height:120px;background:var(--color-bg-secondary);display:flex;align-items:center;justify-content:center;">
                      <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><polygon points="5 3 19 12 5 21 5 3"/></svg>
                    </div>
                  {%- elsif media.media_type == 'model' -%}
                    <div style="width:120px;height:120px;background:var(--color-bg-secondary);display:flex;align-items:center;justify-content:center;">
                      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path d="M21 16V8a2 2 0 00-1-1.73l-7-4a2 2 0 00-2 0l-7 4A2 2 0 003 8v8a2 2 0 001 1.73l7 4a2 2 0 002 0l7-4A2 2 0 0021 16z"/></svg>
                    </div>
                  {%- endif -%}
                </button>
              {%- endfor -%}
            </div>
          {%- endif -%}

          <div class="product-gallery__main" id="gallery-main">
            {%- for media in product.media limit: 1 -%}
              {%- case media.media_type -%}
                {%- when 'image' -%}
                  <img
                    id="gallery-main-img"
                    src="{{ media | image_url: width: 900 }}"
                    srcset="{{ media | image_url: width: 600 }} 600w, {{ media | image_url: width: 900 }} 900w, {{ media | image_url: width: 1200 }} 1200w"
                    sizes="(max-width:768px) 100vw, 50vw"
                    alt="{{ media.alt | default: product.title | escape }}"
                    loading="eager"
                    width="{{ media.width }}"
                    height="{{ media.height }}">
                {%- when 'video' -%}
                  {{ media | media_tag: autoplay: false, loop: false, controls: true, class: 'product-gallery__video' }}
                {%- when 'external_video' -%}
                  <div class="product-gallery__video-wrap" style="aspect-ratio:16/9;">
                    {{ media | external_video_url: autoplay: false | external_video_tag: loading: 'lazy' }}
                  </div>
                {%- when 'model' -%}
                  {{ media | model_viewer_tag: reveal: 'interaction', toggleable: true, data-shopify-feature: '3d-model' }}
              {%- endcase -%}
            {%- else -%}
              {{ 'product-1' | placeholder_svg_tag: 'product-gallery__placeholder' }}
            {%- endfor -%}
          </div>

        </div>
      </div>

      <!-- RIGHT: Scrollable info -->
      <div class="product-layout__info">

        <!-- Category tags -->
        {%- if collection or product.type != blank -%}
          <div class="product-info__tags">
            {%- if collection -%}<span>{{ collection.title }}</span>{%- endif -%}
            {%- if product.type != blank -%}<span class="tag-sep">|</span><span>{{ product.type }}</span>{%- endif -%}
          </div>
        {%- endif -%}

        <!-- Title -->
        <div class="product-info__title-row">
          <h1 class="product-info__title">{{ product.title }}</h1>
        </div>

        <!-- Price -->
        <div class="product-info__price" id="product-price">
          {%- render 'price', product: product, variant: current_variant -%}
        </div>

        <!-- Shop Pay installments -->
        {% form 'product', product %}
          <input type="hidden" name="id" value="{{ current_variant.id }}">
          {{ form | payment_terms }}
        {% endform %}

        <!-- SKU -->
        {%- if current_variant.sku != blank -%}
          <p class="product-info__sku" id="product-sku" style="font-size:0.78rem;color:var(--color-text-muted);margin-bottom:0.5rem;">
            {{ 'products.product.sku' | t }}: <span>{{ current_variant.sku }}</span>
          </p>
        {%- endif -%}

        <hr class="product-info__divider">

        <!-- Variant JSON for JS -->
        <script id="product-variants-json" type="application/json">
          [
            {%- for variant in product.variants -%}
              {
                "id": {{ variant.id }},
                "title": {{ variant.title | json }},
                "price": {{ variant.price }},
                "compare_at_price": {{ variant.compare_at_price | default: 0 }},
                "available": {{ variant.available }},
                "sku": {{ variant.sku | json }},
                "featured_image": {%- if variant.featured_image -%}{{ variant.featured_image | image_url: width: 900 | json }}{%- else -%}null{%- endif -%},
                "options": [
                  {%- for opt in variant.options -%}
                    {{ opt | json }}{%- unless forloop.last -%},{%- endunless -%}
                  {%- endfor -%}
                ]
              }{%- unless forloop.last -%},{%- endunless -%}
            {%- endfor -%}
          ]
        </script>

        <!-- Variant selectors -->
        {%- unless product.has_only_default_variant -%}
          {%- for option in product.options_with_values -%}
            <div class="variant-group" data-variant-group="{{ forloop.index0 }}">
              <p class="variant-label">{{ option.name }} <strong>{{ option.selected_value }}</strong></p>
              <div class="variant-buttons">
                {%- for value in option.values -%}
                  <button
                    class="variant-btn{% if option.selected_value == value %} active{% endif %}"
                    data-option-value="{{ value | escape }}"
                    data-option-index="{{ forloop.parentloop.index0 }}">
                    {{ value }}
                  </button>
                {%- endfor -%}
              </div>
            </div>
          {%- endfor -%}
        {%- endunless -%}

        <!-- In stock / low stock indicator -->
        {%- if current_variant.available -%}
          {%- if current_variant.inventory_management != blank and current_variant.inventory_quantity > 0 and current_variant.inventory_quantity <= 10 -%}
            <div class="low-stock-badge">
              <span class="low-stock-badge__dot"></span>
              Only {{ current_variant.inventory_quantity }} left!
            </div>
          {%- else -%}
            <div class="in-stock-badge">
              <span class="in-stock-badge__dot"></span>
              In Stock
            </div>
          {%- endif -%}
        {%- endif -%}

        <!-- Add to cart -->
        {% form 'product', product, data-add-to-cart-form: '' %}
          <input type="hidden" name="id" id="variant-id-input" value="{{ current_variant.id }}">
          <div class="product-info__add-to-cart">
            <div class="product-info__qty">
              <button type="button" aria-label="Decrease quantity" onclick="var i=this.nextElementSibling;i.value=Math.max(1,+i.value-1)">−</button>
              <input type="number" name="quantity" value="1" min="1" max="99" aria-label="{{ 'products.product.quantity' | t }}">
              <button type="button" aria-label="Increase quantity" onclick="var i=this.previousElementSibling;i.value=Math.min(99,+i.value+1)">+</button>
            </div>
            <button
              type="submit"
              class="btn btn--primary"
              style="flex:1"
              id="add-to-cart-btn"
              data-add-text="{{ 'products.product.add_to_cart' | t | escape }}"
              data-sold-text="{{ 'products.product.sold_out' | t | escape }}"
              {%- unless current_variant.available %} disabled{%- endunless -%}>
              {%- if current_variant.available -%}
                {{ 'products.product.add_to_cart' | t }}
              {%- else -%}
                {{ 'products.product.sold_out' | t }}
              {%- endif -%}
            </button>
          </div>
          <div style="margin-top:0.75rem;">
            {{ form | payment_button }}
          </div>
        {% endform %}

        <!-- Trust badges -->
        <div class="trust-badges">
          <div class="trust-badge">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
            Secure checkout
          </div>
          <div class="trust-badge">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/></svg>
            30-day returns
          </div>
        </div>

        <hr class="product-info__divider">

        <!-- Description -->
        {%- if product.description != blank -%}
          <div class="product-info__description">
            <p class="product-info__description-label">Description</p>
            {{ product.description }}
          </div>
        {%- endif -%}

        <!-- Shop the Collection -->
        {%- if collection and collection.products_count > 1 -%}
          <div class="product-related">
            <p class="product-related__label">Shop the Collection</p>
            <div class="product-related__scroll">
              {%- for p in collection.products limit: 6 -%}
                {%- unless p.id == product.id -%}
                  <a href="{{ p.url }}" class="product-related__item">
                    {%- if p.featured_image -%}
                      <img src="{{ p.featured_image | image_url: width: 120 }}" alt="{{ p.title | escape }}" width="60" height="60" loading="lazy">
                    {%- endif -%}
                    <div>
                      <span class="product-related__title">{{ p.title | truncate: 24 }}</span>
                      <span class="product-related__price">{{ p.price | money }}</span>
                    </div>
                  </a>
                {%- endunless -%}
              {%- endfor -%}
            </div>
          </div>
        {%- endif -%}

      </div>
    </div>
  </div>
</div>

<!-- Full-width image slideshow -->
{%- if product.images.size > 1 -%}
<div class="product-slideshow" id="product-slideshow">
  <div class="product-slideshow__track" id="product-slideshow-track">
    {%- for image in product.images -%}
      <div class="product-slideshow__slide">
        <img
          src="{{ image | image_url: width: 900 }}"
          alt="{{ image.alt | default: product.title | escape }}"
          loading="lazy"
          width="900">
      </div>
    {%- endfor -%}
  </div>
  <button class="product-slideshow__btn product-slideshow__btn--prev" id="slideshow-prev" aria-label="Previous image">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="15 18 9 12 15 6"/></svg>
  </button>
  <button class="product-slideshow__btn product-slideshow__btn--next" id="slideshow-next" aria-label="Next image">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="9 18 15 12 9 6"/></svg>
  </button>
</div>
{%- endif -%}

<!-- Recently Viewed -->
<div class="recently-viewed" id="recently-viewed" style="display:none">
  <div class="container">
    <p class="recently-viewed__label">Recently Viewed</p>
    <div class="recently-viewed__grid" id="recently-viewed-grid"></div>
  </div>
</div>

<script>
  window.__currentProduct = {
    id: {{ product.id }},
    title: {{ product.title | json }},
    url: {{ product.url | json }},
    price: {{ product.price }},
    image: {{ product.featured_image | image_url: width: 400 | json }}
  };
</script>

{% schema %}
{
  "name": "Product",
  "settings": []
}
{% endschema %}
