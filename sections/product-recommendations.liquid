<div
  id="product-recommendations-{{ section.id }}"
  data-product-id="{{ product.id }}"
  data-section-id="{{ section.id }}"
  data-limit="{{ section.settings.products_to_show }}">

  {%- if recommendations.performed and recommendations.products_count > 0 -%}
    <div class="section">
      <div class="container">
        <h2 class="section-title" style="text-align:center;margin-bottom:2rem;">{{ section.settings.heading | default: 'You May Also Like' }}</h2>
        <div class="product-grid">
          {%- for rec in recommendations.products limit: section.settings.products_to_show -%}
            {% render 'product-card', product: rec, show_quick_add: true %}
          {%- endfor -%}
        </div>
      </div>
    </div>
  {%- endif -%}
</div>

<script>
(function() {
  var container = document.getElementById('product-recommendations-{{ section.id }}');
  if (!container) return;
  var productId = container.dataset.productId;
  var sectionId = container.dataset.sectionId;
  var limit = container.dataset.limit || 4;
  if (!productId) return;
  fetch('/recommendations/products?product_id=' + productId + '&limit=' + limit + '&section_id=' + sectionId)
    .then(function(r) { return r.text(); })
    .then(function(html) {
      var doc = new DOMParser().parseFromString(html, 'text/html');
      var newContent = doc.getElementById('product-recommendations-' + sectionId);
      if (newContent && newContent.innerHTML.trim()) container.innerHTML = newContent.innerHTML;
    });
})();
</script>

{% schema %}
{
  "name": "Product recommendations",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "You May Also Like" },
    { "type": "range", "id": "products_to_show", "label": "Products to show", "min": 2, "max": 8, "step": 1, "default": 4 }
  ],
  "presets": [{ "name": "Product recommendations" }]
}
{% endschema %}
