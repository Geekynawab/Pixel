<div class="features-page">
  <div class="container">

    <div class="features-page__hero">
      <p class="section-subtitle">Theme Documentation</p>
      <h1 class="features-page__title">Everything Built Into This Theme</h1>
      <p class="features-page__subtitle">A complete reference of every feature — ready to ship.</p>
    </div>

    <!-- Homepage -->
    <div class="features-category">
      <div class="features-category__header">
        <span class="features-category__icon">🏠</span>
        <h2 class="features-category__title">Homepage</h2>
      </div>
      <div class="features-grid">

        <div class="feature-card">
          <div class="feature-card__icon">🎬</div>
          <h3 class="feature-card__title">Hero Slideshow</h3>
          <p class="feature-card__desc">Full-screen background that cycles through all product images every 4 seconds with a smooth crossfade transition.</p>
          <span class="feature-badge feature-badge--live">Live</span>
        </div>

        <div class="feature-card">
          <div class="feature-card__icon">🚚</div>
          <h3 class="feature-card__title">Trust Bar</h3>
          <p class="feature-card__desc">3-column strip showing Worldwide Shipping, Fast Dispatch (1–3 days), and 30-Day Returns. Stacks on mobile.</p>
          <span class="feature-badge feature-badge--live">Live</span>
        </div>

        <div class="feature-card">
          <div class="feature-card__icon">🛍️</div>
          <h3 class="feature-card__title">Collections Showcase</h3>
          <p class="feature-card__desc">Auto-displays Keychains, Toys, and Mousepads collections with their products and a View All link directly on the homepage.</p>
          <span class="feature-badge feature-badge--live">Live</span>
        </div>

        <div class="feature-card">
          <div class="feature-card__icon">📧</div>
          <h3 class="feature-card__title">Newsletter Signup</h3>
          <p class="feature-card__desc">Email capture form that saves subscribers to your Shopify Customers list tagged as "newsletter".</p>
          <span class="feature-badge feature-badge--live">Live</span>
        </div>

      </div>
    </div>

    <!-- Header & Navigation -->
    <div class="features-category">
      <div class="features-category__header">
        <span class="features-category__icon">🧭</span>
        <h2 class="features-category__title">Header & Navigation</h2>
      </div>
      <div class="features-grid">

        <div class="feature-card">
          <div class="feature-card__icon">📣</div>
          <h3 class="feature-card__title">Announcement Bar</h3>
          <p class="feature-card__desc">Dismissible red top bar for promotions and new drops. Text and link are editable in the theme editor. Remembers dismissal per session.</p>
          <span class="feature-badge feature-badge--live">Live</span>
        </div>

        <div class="feature-card">
          <div class="feature-card__icon">🔍</div>
          <h3 class="feature-card__title">Search Overlay</h3>
          <p class="feature-card__desc">Full-screen dark search panel that opens on icon click. Searches products only. Closes on Escape or click outside.</p>
          <span class="feature-badge feature-badge--live">Live</span>
        </div>

        <div class="feature-card">
          <div class="feature-card__icon">♡</div>
          <h3 class="feature-card__title">Wishlist</h3>
          <p class="feature-card__desc">Heart icon in header with count badge. Customers can save products on cards. Stored in browser localStorage — persists across sessions.</p>
          <span class="feature-badge feature-badge--live">Live</span>
        </div>

        <div class="feature-card">
          <div class="feature-card__icon">👤</div>
          <h3 class="feature-card__title">Customer Accounts</h3>
          <p class="feature-card__desc">Profile icon links to Shopify's hosted account page. Customers can log in, register, view orders and saved addresses.</p>
          <span class="feature-badge feature-badge--live">Live</span>
        </div>

        <div class="feature-card">
          <div class="feature-card__icon">🛒</div>
          <h3 class="feature-card__title">AJAX Cart Drawer</h3>
          <p class="feature-card__desc">Slide-in cart panel with qty controls, remove button, subtotal, and checkout link. No page reload needed.</p>
          <span class="feature-badge feature-badge--live">Live</span>
        </div>

        <div class="feature-card">
          <div class="feature-card__icon">☰</div>
          <h3 class="feature-card__title">Hamburger Nav Drawer</h3>
          <p class="feature-card__desc">Hamburger + MENU label on the left opens a slide-in navigation drawer with accordions for sub-categories. Works on all screen sizes.</p>
          <span class="feature-badge feature-badge--live">Live</span>
        </div>

        <div class="feature-card">
          <div class="feature-card__icon">🍞</div>
          <h3 class="feature-card__title">Global Breadcrumbs</h3>
          <p class="feature-card__desc">Home / Collection / Product path shown on every page — product, collection, cart, search, blog. Hidden on the homepage.</p>
          <span class="feature-badge feature-badge--live">Live</span>
        </div>

      </div>
    </div>

    <!-- Product Page -->
    <div class="features-category">
      <div class="features-category__header">
        <span class="features-category__icon">📦</span>
        <h2 class="features-category__title">Product Page</h2>
      </div>
      <div class="features-grid">

        <div class="feature-card">
          <div class="feature-card__icon">🖼️</div>
          <h3 class="feature-card__title">Vertical Thumbnail Gallery</h3>
          <p class="feature-card__desc">Thumbnails stack vertically on the left. Clicking a thumbnail swaps the large main image on the right. Supports up to 8 images.</p>
          <span class="feature-badge feature-badge--live">Live</span>
        </div>

        <div class="feature-card">
          <div class="feature-card__icon">🔍</div>
          <h3 class="feature-card__title">Image Zoom + Lightbox</h3>
          <p class="feature-card__desc">Hover over the main image to zoom in 2.2× at cursor position. Click to open a full-screen lightbox at 2000px resolution. Closes on Escape or backdrop click.</p>
          <span class="feature-badge feature-badge--live">Live</span>
        </div>

        <div class="feature-card">
          <div class="feature-card__icon">📌</div>
          <h3 class="feature-card__title">Sticky Gallery</h3>
          <p class="feature-card__desc">Left product image stays fixed while the right info panel scrolls, so the image is always visible while reading details.</p>
          <span class="feature-badge feature-badge--live">Live</span>
        </div>

        <div class="feature-card">
          <div class="feature-card__icon">💰</div>
          <h3 class="feature-card__title">Strikethrough Price</h3>
          <p class="feature-card__desc">Every product shows a 30% inflated "was" price in gray strikethrough next to the real price in red. Updates instantly on variant switch.</p>
          <span class="feature-badge feature-badge--live">Live</span>
        </div>

        <div class="feature-card">
          <div class="feature-card__icon">🟢</div>
          <h3 class="feature-card__title">In Stock Badge</h3>
          <p class="feature-card__desc">Green blinking dot with "IN STOCK" text above the Add to Cart button. Disappears automatically when sold out.</p>
          <span class="feature-badge feature-badge--live">Live</span>
        </div>

        <div class="feature-card">
          <div class="feature-card__icon">📦</div>
          <h3 class="feature-card__title">Bulk Savings Tiers</h3>
          <p class="feature-card__desc">Buy 1 / Buy 2 (–15%) / Buy 3 (–25%) selector. Clicking a tier sets the quantity and highlights the selection.</p>
          <span class="feature-badge feature-badge--live">Live</span>
        </div>

        <div class="feature-card">
          <div class="feature-card__icon">⬇️</div>
          <h3 class="feature-card__title">Sticky Add to Cart Bar</h3>
          <p class="feature-card__desc">Slim bar slides up from the bottom when scrolling past the main ATC button. Shows product image, price, and one-tap add to cart.</p>
          <span class="feature-badge feature-badge--live">Live</span>
        </div>

        <div class="feature-card">
          <div class="feature-card__icon">🎠</div>
          <h3 class="feature-card__title">Image Slideshow</h3>
          <p class="feature-card__desc">Full-width carousel below the product showing all images. Shows 3 at a time on desktop. Auto-advances every 4s. Seamless infinite loop. Hover to pause.</p>
          <span class="feature-badge feature-badge--live">Live</span>
        </div>

        <div class="feature-card">
          <div class="feature-card__icon">🔁</div>
          <h3 class="feature-card__title">Variant Switching</h3>
          <p class="feature-card__desc">Selecting a variant updates the price, strikethrough, and Add to Cart availability instantly — no page reload.</p>
          <span class="feature-badge feature-badge--live">Live</span>
        </div>

        <div class="feature-card">
          <div class="feature-card__icon">🛒</div>
          <h3 class="feature-card__title">In Carts Counter</h3>
          <p class="feature-card__desc">FOMO indicator showing how many people currently have the item in their cart. Randomised between 3–12 per page load.</p>
          <span class="feature-badge feature-badge--live">Live</span>
        </div>

        <div class="feature-card">
          <div class="feature-card__icon">🔗</div>
          <h3 class="feature-card__title">Shop the Collection</h3>
          <p class="feature-card__desc">Horizontal scroll of other products from the same collection, shown below the product description.</p>
          <span class="feature-badge feature-badge--live">Live</span>
        </div>

        <div class="feature-card">
          <div class="feature-card__icon">🕵️</div>
          <h3 class="feature-card__title">Recently Viewed</h3>
          <p class="feature-card__desc">Shows the last 4 products the customer browsed in a grid below the slideshow. Stored in localStorage — persists across sessions.</p>
          <span class="feature-badge feature-badge--live">Live</span>
        </div>

      </div>
    </div>

    <!-- Collection Pages -->
    <div class="features-category">
      <div class="features-category__header">
        <span class="features-category__icon">🗂️</span>
        <h2 class="features-category__title">Collection Pages</h2>
      </div>
      <div class="features-grid">

        <div class="feature-card">
          <div class="feature-card__icon">♡</div>
          <h3 class="feature-card__title">Wishlist Hearts on Cards</h3>
          <p class="feature-card__desc">Every product card has a heart button top-right. Fills red when saved. Syncs with the header wishlist count.</p>
          <span class="feature-badge feature-badge--live">Live</span>
        </div>

        <div class="feature-card">
          <div class="feature-card__icon">⚡</div>
          <h3 class="feature-card__title">Quick Add</h3>
          <p class="feature-card__desc">Hover a product card to reveal a Quick Add button that adds directly to cart without visiting the product page.</p>
          <span class="feature-badge feature-badge--live">Live</span>
        </div>

        <div class="feature-card">
          <div class="feature-card__icon">↕️</div>
          <h3 class="feature-card__title">Sort Dropdown</h3>
          <p class="feature-card__desc">Featured, Best Selling, Price (low/high), Newest — changes the URL and re-renders the collection instantly.</p>
          <span class="feature-badge feature-badge--live">Live</span>
        </div>

      </div>
    </div>

    <!-- Trust & Compliance -->
    <div class="features-category">
      <div class="features-category__header">
        <span class="features-category__icon">🛡️</span>
        <h2 class="features-category__title">Trust & Compliance</h2>
      </div>
      <div class="features-grid">

        <div class="feature-card">
          <div class="feature-card__icon">🔒</div>
          <h3 class="feature-card__title">Age Verification Gate</h3>
          <p class="feature-card__desc">Full-screen overlay on first visit asking customers to confirm their age. Decision saved to sessionStorage.</p>
          <span class="feature-badge feature-badge--live">Live</span>
        </div>

        <div class="feature-card">
          <div class="feature-card__icon">🍪</div>
          <h3 class="feature-card__title">Cookie Consent Banner</h3>
          <p class="feature-card__desc">GDPR-style cookie notice at the bottom of the page with an Accept button. Dismissed state stored in localStorage.</p>
          <span class="feature-badge feature-badge--live">Live</span>
        </div>

        <div class="feature-card">
          <div class="feature-card__icon">🤖</div>
          <h3 class="feature-card__title">SEO Meta Tags</h3>
          <p class="feature-card__desc">Open Graph and Twitter Card meta tags on every page for clean social sharing previews.</p>
          <span class="feature-badge feature-badge--live">Live</span>
        </div>

      </div>
    </div>

    <!-- Coming Next -->
    <div class="features-category">
      <div class="features-category__header">
        <span class="features-category__icon">🚧</span>
        <h2 class="features-category__title">Coming Next</h2>
      </div>
      <div class="features-grid">

        <div class="feature-card feature-card--upcoming">
          <div class="feature-card__icon">⚠️</div>
          <h3 class="feature-card__title">Low Stock Warning</h3>
          <p class="feature-card__desc">"Only X left!" badge pulling from real Shopify inventory count.</p>
          <span class="feature-badge feature-badge--upcoming">Up Next</span>
        </div>

        <div class="feature-card feature-card--upcoming">
          <div class="feature-card__icon">⭐</div>
          <h3 class="feature-card__title">Product Reviews</h3>
          <p class="feature-card__desc">Judge.me integration for star ratings and customer reviews on product pages.</p>
          <span class="feature-badge feature-badge--upcoming">Planned</span>
        </div>

        <div class="feature-card feature-card--upcoming">
          <div class="feature-card__icon">📩</div>
          <h3 class="feature-card__title">Email Popup</h3>
          <p class="feature-card__desc">Timed popup (5s delay) capturing email signups. Saves to Shopify Customers list.</p>
          <span class="feature-badge feature-badge--upcoming">Planned</span>
        </div>

        <div class="feature-card feature-card--upcoming">
          <div class="feature-card__icon">⏱️</div>
          <h3 class="feature-card__title">Countdown Timer</h3>
          <p class="feature-card__desc">Urgency clock on product pages — "Offer ends in X:XX:XX".</p>
          <span class="feature-badge feature-badge--upcoming">Planned</span>
        </div>

        <div class="feature-card feature-card--upcoming">
          <div class="feature-card__icon">📦</div>
          <h3 class="feature-card__title">Free Shipping Progress Bar</h3>
          <p class="feature-card__desc">"Add $X more for free shipping" bar inside the cart drawer.</p>
          <span class="feature-badge feature-badge--upcoming">Planned</span>
        </div>

        <div class="feature-card feature-card--upcoming">
          <div class="feature-card__icon">📱</div>
          <h3 class="feature-card__title">Sticky Mobile Bottom Bar</h3>
          <p class="feature-card__desc">Home, Search, Wishlist, and Cart icons pinned at the bottom on mobile for thumb-friendly navigation.</p>
          <span class="feature-badge feature-badge--upcoming">Planned</span>
        </div>

        <div class="feature-card feature-card--upcoming">
          <div class="feature-card__icon">↑</div>
          <h3 class="feature-card__title">Back to Top Button</h3>
          <p class="feature-card__desc">Appears after scrolling down, smooth-scrolls back to the top on click.</p>
          <span class="feature-badge feature-badge--upcoming">Planned</span>
        </div>

        <div class="feature-card feature-card--upcoming">
          <div class="feature-card__icon">🔀</div>
          <h3 class="feature-card__title">Upsell in Cart</h3>
          <p class="feature-card__desc">"Customers also bought" product row inside the cart drawer before checkout.</p>
          <span class="feature-badge feature-badge--upcoming">Planned</span>
        </div>

      </div>
    </div>

  </div>
</div>

{% schema %}
{
  "name": "Features Page",
  "settings": []
}
{% endschema %}
