<div class="section" style="min-height:80vh;display:flex;align-items:center;justify-content:center;">
  <div class="container" style="max-width:480px;text-align:center;">

    {%- if shop.password_message != blank -%}
      <p style="color:var(--color-text-secondary);font-size:0.88rem;margin-bottom:2rem;">{{ shop.password_message }}</p>
    {%- endif -%}

    <h1 style="font-size:clamp(1.5rem,3vw,2rem);margin-bottom:0.75rem;">{{ 'general.password_page.title' | t | default: 'Coming Soon' }}</h1>
    <p style="color:var(--color-text-secondary);margin-bottom:2rem;">{{ 'general.password_page.subtext' | t | default: 'We are working on something awesome. Enter the password to get early access.' }}</p>

    {%- form 'storefront_password' -%}
      {%- if form.errors -%}
        <p style="color:#ff4655;font-size:0.82rem;margin-bottom:1rem;">{{ 'general.password_page.login_password_error' | t | default: 'Wrong password. Try again.' }}</p>
      {%- endif -%}
      <div style="display:flex;gap:0.5rem;max-width:360px;margin:0 auto;">
        <label for="password" class="visually-hidden">{{ 'general.password_page.login_form_password_label' | t | default: 'Password' }}</label>
        <input
          type="password"
          name="password"
          id="password"
          style="flex:1;background:var(--color-bg-card);border:1px solid var(--color-border);color:var(--color-text-primary);padding:0.75rem 1rem;font-size:0.9rem;outline:none;"
          placeholder="{{ 'general.password_page.login_form_password_placeholder' | t | default: 'Your password' }}"
          autofocus>
        <button type="submit" class="btn btn--primary">{{ 'general.password_page.login_form_submit' | t | default: 'Enter' }}</button>
      </div>
    {%- endform -%}

    <p style="margin-top:2.5rem;font-size:0.75rem;color:var(--color-text-muted);">
      {{ 'general.password_page.owner_html' | t | default: 'Are you the store owner?' | append: ' <a href="/admin" style="color:var(--color-accent);">Log in here</a>' }}
    </p>

  </div>
</div>

{% schema %}
{
  "name": "Password",
  "settings": []
}
{% endschema %}
